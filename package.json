{
  "name": "@peter.naydenov/dom-selector",
  "description": "DOM selections and DOM references organizer",
  "version": "3.1.3",
  "license": "MIT",
  "author": "Peter Naydenov",
  "main": "./src/main.js",
  "type": "module",
  "types": "./types/main.d.ts",
  "exports": {
    ".": {
      "import": "./src/main.js",
      "require": "./dist/dom-selector.cjs",
      "default": "./src/main.js"
    },
    "./package.json": "./package.json",
    "./dist/*": "./dist/*",
    "./src/*": "./src/*"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "postbuild": "tsc -p tsconfig.json",
    "preview": "vite preview",
    "test": "playwright test",
    "test:ui": "playwright test --ui"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PeterNaydenov/dom-selector.git"
  },
  "devDependencies": {
    "@peter.naydenov/visual-controller-for-vue3": "^2.3.1",
    "@playwright/test": "^1.61.0",
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^26.1.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "chai": "^6.2.2",
    "http-server": "^14.1.1",
    "jsdom": "^29.1.1",
    "serve": "^14.2.6",
    "typescript": "^6.0.3",
    "vite": "^8.1.4",
    "vue": "^3.5.39"
  },
  "keywords": [
    "dom",
    "select",
    "html",
    "scan"
  ],
  "allowScripts": {
    "fsevents@2.3.3": true,
    "fsevents@2.3.2": true
  }
}
